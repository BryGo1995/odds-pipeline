flowchart TD
    OddsAPI["The Odds API"]

    subgraph Airflow["Apache Airflow"]
        Ingest["nba_ingest\n8am & 8pm daily"]
        Transform["nba_transform\n15 min after ingest"]
        PlayerProps["nba_player_props\n10pm daily"]
    end

    subgraph DB["PostgreSQL"]
        Raw[("Raw Layer\nraw_api_responses")]
        Normalized[("Normalized Layer\ngames · odds · scores · player_props")]
    end

    Slack["Slack"]

    OddsAPI -->|"Fetch events, odds, scores"| Ingest
